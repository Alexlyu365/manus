# ============================================================
# 网站环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件包含敏感信息，请勿提交到 Git 仓库
# ============================================================

# ── 站点基本信息 ──────────────────────────────────────────────────────────────
DOMAIN=example.com
SITE_NAME=example_com
APP_PORT=3000

# ── 数据库连接（由部署脚本自动生成，也可手动填写）────────────────────────────
DB_HOST=manus-mysql
DB_PORT=3306
DB_NAME=site_example_com
DB_USER=site_example_com_user
DB_PASS=your_database_password_here

# ── 应用密钥（随机生成，用于加密 Session 等）─────────────────────────────────
APP_KEY=your_app_secret_key_here
APP_SECRET=your_app_secret_here

# ── 时区 ──────────────────────────────────────────────────────────────────────
TZ=Asia/Shanghai
NODE_ENV=production

# ── 文件存储（本地存储路径）──────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=524288000   # 500MB in bytes

# ── 邮件配置（可选，用于联系表单等）─────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password

# ── 其他自定义变量 ────────────────────────────────────────────────────────────
# CUSTOM_VAR=value
